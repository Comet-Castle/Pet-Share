# Public app configuration.
# Also used to build absolute URLs for the logo/pattern images embedded in the
# acknowledgement email, since email clients require real hosted image URLs, and
# as the metadataBase for SEO — canonical URLs, og:url, and the OG/Twitter image
# (public/og-default.png) must be absolute for social scrapers. Leave blank locally
# (falls back to http://localhost:3000); set the real production URL on deploy.
NEXT_PUBLIC_SITE_URL=

# Server-only runtime diagnostics
APP_DEBUG=false

# Sanity project configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=u0596eb6
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# Server-only Sanity credentials
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Optional browser-readable Sanity viewer token for draft live updates in Presentation.
# Use a least-privilege read token only. Leave blank to keep draft live events disabled in the browser.
SANITY_API_BROWSER_READ_TOKEN=

# Optional manual preview fallback and webhook secrets
SANITY_PREVIEW_SECRET=
SANITY_REVALIDATE_SECRET=

# Public Studio preview target used by Sanity Presentation.
# Use http://localhost:3000 locally and the Vercel deployment URL in hosted environments.
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:3000

# Optional Studio Media Library ID. Leave blank to let Sanity auto-detect the connected library.
SANITY_STUDIO_MEDIA_LIBRARY_ID=

# Server-only email provider credentials and delivery target
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=
# Optional, defaults to https://api.mailgun.net. Use https://api.eu.mailgun.net for EU domains.
MAILGUN_API_BASE=
# Optional server-only internal oversight address CC'd on outgoing form emails. Leave blank to disable.
MAILGUN_CC_EMAIL=

# Server-only AI generation credentials
# Used only by intentional seed generation scripts, not by the public app runtime.
# Create a key through Google AI Studio: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=
