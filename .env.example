# Public app configuration
NEXT_PUBLIC_SITE_URL=

# Server-only runtime diagnostics
APP_DEBUG=false

# Sanity project configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=u0596eb6
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# Server-only Sanity credentials
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Preview and webhook secrets
SANITY_PREVIEW_SECRET=
SANITY_REVALIDATE_SECRET=

# Server-only email provider credentials and delivery target
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=

# Server-only destination inbox for form submissions
CONTACT_TO_EMAIL=

# Server-only AI generation credentials
# Used only by intentional seed generation scripts, not by the public app runtime.
# Create a key through Google AI Studio: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=
