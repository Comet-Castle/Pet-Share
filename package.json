{
  "name": "pet-share",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "seed:media": "node scripts/seed-media.mjs",
    "seed:sanity": "node scripts/seed-sanity.mjs",
    "seed:wizard": "node scripts/seed-wizard.mjs",
    "studio": "sanity dev",
    "studio:build": "sanity build"
  },
  "dependencies": {
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^6.2.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-sanity": "^13.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^6.2.0",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
